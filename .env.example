# ─────────────────────────────────────────────────────────────
# Dessert Shop — Frontend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────
# All variables exposed to the browser MUST be prefixed VITE_

# Base URL for the backend API
# Development: leave as /api (Vite proxy handles it)
# Production:  set to your deployed backend URL
VITE_API_BASE_URL=/api

# Backend server URL (used by Vite dev proxy)
VITE_API_URL=http://localhost:7000

# App display name
VITE_APP_NAME=Dessert Shop
